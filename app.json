{
  "expo": {
    "name": "Paul's Tools",
    "slug": "paul-tools",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "scheme": "paultools",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.paulfulfer.paultools"
    },
    "android": {
      "package": "com.paulfulfer.paultools",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d1117"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "@react-native-google-signin/google-signin",
      "@react-native-community/datetimepicker",
      "expo-font",
      "expo-web-browser"
    ],
    "updates": {
      "enabled": true,
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/44428a85-9987-4d8a-9ac0-65adc9b9edb8"
    },
    "runtimeVersion": "1.0.0",
    "extra": {
      "eas": {
        "projectId": "44428a85-9987-4d8a-9ac0-65adc9b9edb8"
      }
    }
  }
}
