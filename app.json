{
  "expo": {
    "name": "PaulTools",
    "slug": "paul-tools",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "paultools",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.paulfulfer.paultools"
    },
    "android": {
      "package": "com.paulfulfer.paultools",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#0d1117"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "@react-native-google-signin/google-signin",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "44428a85-9987-4d8a-9ac0-65adc9b9edb8"
      }
    }
  }
}
