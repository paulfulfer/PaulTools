{
  "expo": {
    "name": "PaulTools",
    "slug": "paul-tools",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "paultools",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.paulfulfer.paultools"
    },
    "android": {
      "package": "com.paulfulfer.paultools",
      "adaptiveIcon": {
        "backgroundColor": "#0d1117"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "@react-native-google-signin/google-signin"
    ]
  }
}
